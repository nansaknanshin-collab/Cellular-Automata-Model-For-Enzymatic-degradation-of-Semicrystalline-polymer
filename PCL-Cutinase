def _present_states_from_arrays(arrays):
    present = set()

    for arr in arrays:
        present.update(np.unique(arr).astype(int).tolist())

    return present


def add_bottom_legend(
    fig,
    present_states=None,
    include_enzyme=False,
    include_oligomer=False,
    binary_void_values=None,
    y_anchor=0.015
):
    legend_patches = []

    if present_states is not None:
        ordered_states = [S_CRYST, S_AMORPH, S_DEG, S_VOID]

        labels = {
            S_CRYST: "Crystalline (C)",
            S_AMORPH: "Amorphous (A)",
            S_DEG: "Degraded (D)",
            S_VOID: "Void / eroded (V)",
        }

        for state in ordered_states:
            if state in present_states:
                legend_patches.append(
                    mpatches.Patch(
                        facecolor=SPECIES_COLOURS[state],
                        edgecolor="black",
                        label=labels[state]
                    )
                )

    if binary_void_values is not None:
        vals = set(int(v) for v in binary_void_values)

        if 0 in vals:
            legend_patches.append(
                mpatches.Patch(
                    facecolor="#C8C8C8",
                    edgecolor="black",
                    label="Polymer"
                )
            )

        if 1 in vals:
            legend_patches.append(
                mpatches.Patch(
                    facecolor=SPECIES_COLOURS[S_VOID],
                    edgecolor="black",
                    label="Void / eroded (V)"
                )
            )

    if include_enzyme:
        legend_patches.append(
            mpatches.Patch(
                facecolor=ENZYME_COLOUR,
                edgecolor="black",
                label="Enzyme"
            )
        )

    if include_oligomer:
        legend_patches.append(
            mpatches.Patch(
                facecolor="#7300D9",
                edgecolor="black",
                label="Soluble oligomer"
            )
        )

    if not legend_patches:
        return

    fig.legend(
        handles=legend_patches,
        loc="lower center",
        ncol=len(legend_patches),
        fontsize=15,
        frameon=True,
        bbox_to_anchor=(0.5, y_anchor),
        handlelength=2.8,
        columnspacing=1.8,
        borderpad=0.8
    )


def plot_snapshot_set(
    images,
    snapshot_times,
    out_name,
    cmap=None,
    norm=None,
    vmin=None,
    vmax=None,
    add_legend=True,
    legend_mode="species"
):
    fig, axes = plt.subplots(
        len(snapshot_times),
        1,
        figsize=(18, 1.55 * len(snapshot_times)),
        constrained_layout=False
    )

    if len(snapshot_times) == 1:
        axes = [axes]

    for ax, tt in zip(axes, snapshot_times):
        img = images[float(tt)]

        ax.imshow(
            img,
            cmap=cmap,
            norm=norm,
            interpolation="nearest",
            aspect="auto",
            vmin=vmin if norm is None else None,
            vmax=vmax if norm is None else None
        )

        ax.set_ylabel(
            f"t = {tt:g} h",
            fontsize=18,
            fontweight="bold",
            rotation=0,
