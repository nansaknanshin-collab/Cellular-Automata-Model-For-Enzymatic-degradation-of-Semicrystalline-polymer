    plt.show()

    print(f"Saved: {out_name}")


def crop_center_square(img, size_cells=ZOOM_SIZE_CELLS):
    ny, nx = img.shape
    size = int(max(1, min(size_cells, ny, nx)))

    j0 = ny // 2 - size // 2
    i0 = nx // 2 - size // 2

    return img[j0:j0 + size, i0:i0 + size]


def add_scale_bar_to_axis(
    ax,
    image_shape,
    zoom_field_width_um=ZOOM_FIELD_WIDTH_UM,
    scale_bar_um=SCALE_BAR_UM,
    colour="white",
    text_colour="white"
):
    ny, nx = image_shape

    cell_size_um = zoom_field_width_um / float(nx)
    bar_cells = scale_bar_um / cell_size_um
    bar_cells = min(bar_cells, 0.70 * nx)

    x1 = 0.92 * nx
    x0 = x1 - bar_cells
    y0 = 0.90 * ny

    ax.plot(
        [x0, x1],
        [y0, y0],
        color=colour,
        lw=5,
        solid_capstyle="butt"
    )

    ax.text(
        0.5 * (x0 + x1),
        y0 - 0.06 * ny,
        f"{scale_bar_um:.0f} µm",
        color=text_colour,
        fontsize=13,
        ha="center",
        va="bottom",
        fontweight="bold"
    )


