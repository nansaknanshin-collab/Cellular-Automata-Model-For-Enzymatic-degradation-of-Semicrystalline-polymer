# 10) SAVE SNAPSHOT METRICS
# ============================================================
def save_snapshot_metrics(t_snap, wl_snap, xc_snap, mn_snap, olig_snap):
    out_path = os.path.join(
        OUTPUT_DIR,
        f"{CURRENT_POLYMER}_snapshot_metrics.tsv"
    )

    with open(out_path, "w") as f:
        f.write(
            "time_h\tweight_loss_percent\tremaining_crystallinity_percent\t"
            "Mn_global_g_mol\toligomer_inside_percent\n"
        )

