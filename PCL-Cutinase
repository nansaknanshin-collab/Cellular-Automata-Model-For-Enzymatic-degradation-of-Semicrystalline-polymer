        f"{CURRENT_POLYMER}_snapshot_metrics.xlsx"
    )

    metrics_df = pd.DataFrame({
        "time_h": t_snap,
        "weight_loss_percent": 100.0 * wl_snap,
        "remaining_crystallinity_percent": 100.0 * xc_snap,
        "Mn_global_g_mol": mn_snap,
        "oligomer_inside_percent": 100.0 * olig_snap,
    })

    metrics_df.to_excel(metrics_excel_path, index=False)

    print(f"\nSaved summary:\n{summary_path}")
    print(f"Saved Excel metrics:\n{metrics_excel_path}")
    print("\nDone.")
