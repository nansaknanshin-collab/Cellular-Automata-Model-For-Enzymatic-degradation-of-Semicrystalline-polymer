        print(f"RUNNING SNAPSHOTS FOR {polymer_name}")
        print("=" * 70)
        print(f"MN0 = {MN0:.2f} g/mol")
        print(f"X_FIXED = {X_FIXED:.4f}")

        print("\n================ FIXED PARAMETERS ================")
        for nm, val in zip(names, THETA_FIXED):
