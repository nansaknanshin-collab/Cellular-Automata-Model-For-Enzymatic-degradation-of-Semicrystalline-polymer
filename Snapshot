            for key, path in output_files.items():
                f.write(f"output_{key}\t{path}\n")

        print(f"Saved summary: {summary_path}")

        for tt, wl, xc, mn, olig in zip(t_snap, wl_snap, xc_snap, mn_snap, olig_snap):
