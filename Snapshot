def plot_combined_zoom_snapshot_grid(all_snapshots_by_polymer, snapshot_times):
    """
    Put the central zoomed snapshots together in one SEM-style panel:

        columns = PCL-6300, PCL-6500, PCL-6800
        rows    = 0, 1, 2, 4, 6, 8, 12, 16, 20 h

    This version reduces the large white space between columns by using
    near-square subplot slots and tighter horizontal spacing.

    Three combined figures are saved:
      1) species colour zoom grid
      2) SEM-like void/solid zoom grid
      3) species + enzyme overlay zoom grid
    """
    polymer_order = ["PCL6300", "PCL6500", "PCL6800"]
    n_rows = len(snapshot_times)
    n_cols = len(polymer_order)

    combined_dir = os.path.join(OUTPUT_DIR, "Combined_zoom_grids")
    os.makedirs(combined_dir, exist_ok=True)

    # Key layout fix:
    # The previous width, 4.65 inches per column, was too wide for square images.
    # This made each square sit in the middle of a wide subplot, producing the
    # large white vertical bands between columns. These settings make the subplot
    # slots closer to square and keep only a narrow SEM-style gap.
    COMBINED_FIGSIZE = (3.15 * n_cols, 3.15 * n_rows)
    COMBINED_ADJUST = dict(
        left=0.115,
        right=0.995,
        top=0.975,
        bottom=0.055,
        wspace=0.045,
        hspace=0.045
    )

    def _format_axes(ax, tt, col_idx, row_idx, polymer_name):
        ax.set_xticks([])
        ax.set_yticks([])

        if row_idx == 0:
            ax.set_title(
                polymer_display_name(polymer_name),
                fontsize=24,
                fontweight="bold",
                pad=4
            )

        if col_idx == 0:
            ax.set_ylabel(
                f"{tt:g}h",
                fontsize=24,
                rotation=0,
                labelpad=10,
                va="center",
                ha="right"
            )

    # --------------------------------------------------------
    # A) Species-colour combined zoom grid
    # --------------------------------------------------------
    fig, axes = plt.subplots(
        n_rows,
        n_cols,
        figsize=COMBINED_FIGSIZE,
        constrained_layout=False
    )

    if n_rows == 1:
        axes = np.array([axes])

    for r, tt in enumerate(snapshot_times):
        for c, polymer_name in enumerate(polymer_order):
            ax = axes[r, c]
            phase = all_snapshots_by_polymer[polymer_name]["phase"][float(tt)]
            phase_zoom = crop_center_square(phase)

            ax.imshow(
                phase_zoom,
                cmap=cmap_species,
                norm=norm_species,
                interpolation="nearest",
                aspect="equal"
            )

            add_scale_bar_to_axis(
                ax,
                phase_zoom.shape,
                colour="white",
                text_colour="white"
            )

            _format_axes(ax, tt, c, r, polymer_name)

    present_states = set()
    for polymer_name in polymer_order:
        for tt in snapshot_times:
            phase = crop_center_square(
                all_snapshots_by_polymer[polymer_name]["phase"][float(tt)]
            )
            present_states.update(np.unique(phase).astype(int).tolist())

    add_bottom_legend(fig, present_states=present_states, y_anchor=0.012)
    plt.subplots_adjust(**COMBINED_ADJUST)

    out_species = os.path.join(
        combined_dir,
        f"All_PCL_combined_species_zoom_grid_{ROWS}x{COLS}.png"
    )
    plt.savefig(out_species, dpi=600, bbox_inches="tight", pad_inches=0.02)
    plt.show()
    print(f"Saved combined species zoom grid: {out_species}")

    # --------------------------------------------------------
    # B) SEM-like void/solid combined zoom grid
    # --------------------------------------------------------
    sem_void_cmap = mcolors.ListedColormap([
        "#C8C8C8",  # non-void polymer-like background
        "#000000",  # void / deep pore
    ])
    sem_void_norm = mcolors.BoundaryNorm([-0.5, 0.5, 1.5], sem_void_cmap.N)

    fig, axes = plt.subplots(
        n_rows,
        n_cols,
        figsize=COMBINED_FIGSIZE,
        constrained_layout=False
    )

    if n_rows == 1:
        axes = np.array([axes])

    for r, tt in enumerate(snapshot_times):
        for c, polymer_name in enumerate(polymer_order):
            ax = axes[r, c]
            phase = all_snapshots_by_polymer[polymer_name]["phase"][float(tt)]
            phase_zoom = crop_center_square(phase)
            void_zoom = np.where(phase_zoom == S_VOID, 1, 0)

            ax.imshow(
                void_zoom,
                cmap=sem_void_cmap,
                norm=sem_void_norm,
                interpolation="nearest",
                aspect="equal"
            )

            add_scale_bar_to_axis(
                ax,
                void_zoom.shape,
                colour="white",
                text_colour="white"
            )

            _format_axes(ax, tt, c, r, polymer_name)

    add_bottom_legend(fig, binary_void_values={0, 1}, y_anchor=0.012)
    plt.subplots_adjust(**COMBINED_ADJUST)

    out_void = os.path.join(
        combined_dir,
        f"All_PCL_combined_void_zoom_grid_{ROWS}x{COLS}.png"
    )
    plt.savefig(out_void, dpi=600, bbox_inches="tight", pad_inches=0.02)
    plt.show()
    print(f"Saved combined void zoom grid: {out_void}")

    # --------------------------------------------------------
    # C) Species + enzyme overlay combined zoom grid
    # --------------------------------------------------------
    fig, axes = plt.subplots(
        n_rows,
        n_cols,
        figsize=COMBINED_FIGSIZE,
        constrained_layout=False
    )

    if n_rows == 1:
        axes = np.array([axes])

    for r, tt in enumerate(snapshot_times):
        for c, polymer_name in enumerate(polymer_order):
            ax = axes[r, c]
            phase = all_snapshots_by_polymer[polymer_name]["phase"][float(tt)]
            enzyme = all_snapshots_by_polymer[polymer_name]["enzyme"][float(tt)]

            phase_zoom = crop_center_square(phase)
            enzyme_zoom = crop_center_square(enzyme)

            ax.imshow(
                phase_zoom,
                cmap=cmap_species,
                norm=norm_species,
                interpolation="nearest",
                aspect="equal"
            )

            enzyme_alpha = np.clip(enzyme_zoom / E_BATH, 0.0, 1.0) * 0.55
            ax.imshow(
                np.ones_like(enzyme_zoom),
                cmap=mcolors.ListedColormap([ENZYME_COLOUR]),
                interpolation="nearest",
                aspect="equal",
                alpha=enzyme_alpha,
                vmin=0,
                vmax=1
            )

            add_scale_bar_to_axis(
                ax,
                phase_zoom.shape,
                colour="white",
                text_colour="white"
            )

            _format_axes(ax, tt, c, r, polymer_name)

    add_bottom_legend(
        fig,
        present_states=present_states,
        include_enzyme=True,
        y_anchor=0.012
    )
    plt.subplots_adjust(**COMBINED_ADJUST)

    out_overlay = os.path.join(
        combined_dir,
        f"All_PCL_combined_species_enzyme_zoom_grid_{ROWS}x{COLS}.png"
    )
    plt.savefig(out_overlay, dpi=600, bbox_inches="tight", pad_inches=0.02)
    plt.show()
    print(f"Saved combined species + enzyme zoom grid: {out_overlay}")

    return {
        "combined_species_zoom_grid": out_species,
        "combined_void_zoom_grid": out_void,
        "combined_species_enzyme_zoom_grid": out_overlay,
    }


