    print("Parameters substituted from the refined 30 x 999 calibrated-parameter table supplied by the user.")
    print("Output structure: remaining polymer, enzyme, void, oligomer, all-species overlay, plus SEM-style zoom snapshots.")
    print(f"Snapshot times: {t_fit}")

    names = [
        "k1", "k3", "k_conv", "k_deg_C", "k_deg_A", "Mnc", "k_det",
