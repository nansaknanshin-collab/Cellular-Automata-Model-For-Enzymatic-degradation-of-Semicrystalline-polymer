def _present_states_from_arrays(arrays):
    """Return the set of CA states that appear in a list/dict of arrays."""
    present = set()
    for arr in arrays:
        present.update(np.unique(arr).astype(int).tolist())
    return present


def add_bottom_legend(
    fig,
    present_states=None,
    include_enzyme=False,
    include_oligomer=False,
    binary_void_values=None,
    y_anchor=0.015
):
    """
    Add a legend containing only colours that are actually used in the plotted
    snapshot type.

    - present_states: CA states present in species snapshots.
    - include_enzyme: add enzyme legend entry for enzyme-only or overlay plots.
    - include_oligomer: add oligomer legend entry for oligomer-only plots.
    - binary_void_values: set/list of values in void-only maps, where
      0 = non-void background and 1 = void.
    """
    legend_patches = []

    if present_states is not None:
        ordered_states = [S_CRYST, S_AMORPH, S_DEG, S_VOID]
        labels = {
            S_CRYST: "Crystalline (C)",
            S_AMORPH: "Amorphous (A)",
            S_DEG: "Degraded (D)",
            S_VOID: "Void / eroded (V)",
        }

        for state in ordered_states:
            if state in present_states:
                legend_patches.append(
                    mpatches.Patch(
                        facecolor=SPECIES_COLOURS[state],
                        edgecolor="black",
                        label=labels[state]
                    )
                )

    if binary_void_values is not None:
        vals = set(int(v) for v in binary_void_values)
        if 0 in vals:
            legend_patches.append(
                mpatches.Patch(
                    facecolor="#C8C8C8",
                    edgecolor="black",
                    label="Polymer"
                )
            )
        if 1 in vals:
            legend_patches.append(
                mpatches.Patch(
                    facecolor=SPECIES_COLOURS[S_VOID],
                    edgecolor="black",
                    label="Void / eroded (V)"
                )
            )

    if include_enzyme:
        legend_patches.append(
            mpatches.Patch(
                facecolor=ENZYME_COLOUR,
                edgecolor="black",
                label="Enzyme"
            )
        )

    if include_oligomer:
        legend_patches.append(
            mpatches.Patch(
                facecolor="#7300D9",
                edgecolor="black",
                label="Soluble oligomer"
            )
        )

    if not legend_patches:
        return

    fig.legend(
        handles=legend_patches,
        loc="lower center",
        ncol=len(legend_patches),
        fontsize=15,
        frameon=True,
        bbox_to_anchor=(0.5, y_anchor),
        handlelength=2.8,
        columnspacing=1.8,
        borderpad=0.8
    )


def plot_snapshot_set(
    images,
    snapshot_times,
    title,
    out_name,
    cmap=None,
    norm=None,
    vmin=None,
    vmax=None,
