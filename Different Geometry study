# 13) MAIN
# ============================================================
if __name__ == "__main__":
    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")

    print("\n================ GEOMETRY STUDY ================")
    print("No calibration is performed.")
    print("The PCL6800 calibrated parameters are fixed.")
    print(f"TARGET_ROWS = {TARGET_ROWS}")
    print(f"Number of stochastic repeats per geometry = {N_REP}")

    record_times = np.linspace(0, T_END, 101)

    all_results = []

    for geom in GEOMETRY_CASES:
        print("\n------------------------------------------------")
        print(f"Running geometry: {geom['name']}")
        print(f"Length = {geom['length_mm']} mm")
        print(f"Thickness = {geom['thickness_mm']} mm")

        result = simulate_geometry_case(
            theta=THETA_FIXED,
            geometry=geom,
            record_times=record_times
        )

        print(f"Grid used: {result['rows']} x {result['cols']}")
        print(f"Final WL = {100.0 * result['wl_mean'][-1]:.2f}%")
        print(f"Final Xc = {100.0 * result['xc_mean'][-1]:.2f}%")

        all_results.append(result)

    # ========================================================
    # SAVE EXCEL RESULTS
    # ========================================================
    excel_path = os.path.join(
        OUTPUT_DIR,
        f"PCL6800_thickness_geometry_study_fixed_params_{timestamp}.xlsx"
    )

    summary_rows = []

    with pd.ExcelWriter(excel_path, engine="openpyxl") as writer:
        for res in all_results:
            df = pd.DataFrame({
                "time_h": res["time"],
                "WL_mean_percent": 100.0 * res["wl_mean"],
                "WL_sd_percent": 100.0 * res["wl_sd"],
                "Xc_mean_percent": 100.0 * res["xc_mean"],
                "Xc_sd_percent": 100.0 * res["xc_sd"],
                "Porosity_mean_percent": 100.0 * res["porosity_mean"],
                "Porosity_sd_percent": 100.0 * res["porosity_sd"],
                "Mn_mean_g_per_mol": res["mn_mean"],
                "Mn_sd_g_per_mol": res["mn_sd"],
            })

            df.to_excel(writer, sheet_name=res["name"][:31], index=False)

            t50 = time_to_threshold(res["time"], res["wl_mean"], 0.50)

            summary_rows.append({
                "Geometry": res["name"],
                "Length_mm": res["length_mm"],
                "Thickness_mm": res["thickness_mm"],
                "Rows": res["rows"],
                "Cols": res["cols"],
                "DX": res["dx"],
                "Final_WL_percent": 100.0 * res["wl_mean"][-1],
                "Final_Xc_percent": 100.0 * res["xc_mean"][-1],
                "Final_Porosity_percent": 100.0 * res["porosity_mean"][-1],
                "Final_Mn_g_per_mol": res["mn_mean"][-1],
                "Time_to_50_percent_WL_h": t50,
            })

        summary_df = pd.DataFrame(summary_rows)
        summary_df.to_excel(writer, sheet_name="Summary", index=False)

    # ========================================================
    # PLOT 1: WEIGHT LOSS — THICKNESS GEOMETRIES
    # ========================================================
    fig, ax = plt.subplots(figsize=(9, 6))

    for res in all_results:
        ax.plot(
            res["time"],
            100.0 * res["wl_mean"],
            lw=3,
            label=f"{res['thickness_mm']} mm ({res['rows']}x{res['cols']})"
        )

    ax.set_xlabel("Time (h)", fontsize=18)
    ax.set_ylabel("Weight loss (%)", fontsize=18)
    ax.tick_params(axis="both", labelsize=15)
    ax.xaxis.set_major_locator(MaxNLocator(integer=True))
    ax.yaxis.set_major_locator(MaxNLocator(integer=True))
    ax.grid(alpha=0.3)
    ax.legend(fontsize=10, frameon=True)

    plt.tight_layout()

    wl_fig_path = os.path.join(
        OUTPUT_DIR,
        f"PCL6800_thickness_weight_loss_fixed_params_{timestamp}.png"
    )

    plt.savefig(wl_fig_path, dpi=600, bbox_inches="tight")
    plt.show()

    # ========================================================
    # PLOT 2: CRYSTALLINITY — THICKNESS GEOMETRIES
    # ========================================================
    fig, ax = plt.subplots(figsize=(9, 6))

    for res in all_results:
        ax.plot(
            res["time"],
            100.0 * res["xc_mean"],
            lw=3,
            label=f"{res['thickness_mm']} mm ({res['rows']}x{res['cols']})"
        )

    ax.set_xlabel("Time (h)", fontsize=18)
    ax.set_ylabel("Remaining crystallinity (%)", fontsize=18)
    ax.tick_params(axis="both", labelsize=15)
    ax.xaxis.set_major_locator(MaxNLocator(integer=True))
    ax.yaxis.set_major_locator(MaxNLocator(integer=True))
    ax.grid(alpha=0.3)
    ax.legend(fontsize=10, frameon=True)

    plt.tight_layout()

    xc_fig_path = os.path.join(
        OUTPUT_DIR,
        f"PCL6800_thickness_crystallinity_fixed_params_{timestamp}.png"
    )

    plt.savefig(xc_fig_path, dpi=600, bbox_inches="tight")
    plt.show()

    # ========================================================
    # SAVE SUMMARY TABLE
    # ========================================================
    summary_path = os.path.join(
        OUTPUT_DIR,
        f"PCL6800_thickness_geometry_summary_fixed_params_{timestamp}.tsv"
    )

    summary_df.to_csv(summary_path, sep="\t", index=False)

    print("\n================ SAVED FILES ================")
    print(f"Excel results: {excel_path}")
    print(f"Summary table: {summary_path}")
    print(f"Weight loss plot: {wl_fig_path}")
    print(f"Crystallinity plot: {xc_fig_path}")

    print("\nDone.")
