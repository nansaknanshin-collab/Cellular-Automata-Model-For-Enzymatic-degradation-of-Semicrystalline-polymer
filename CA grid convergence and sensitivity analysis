def plot_full_wireframe(ax, X, Y, Z, line_width=1.6, color="black"):
    """
    Draw both wireframe directions explicitly using one fixed colour.

    This avoids the default multi-colour 3D line cycling and forces all
    horizontal and vertical wireframe lines to use the same visual style.
    """
    # Lines along time for each grid size
    for i in range(Z.shape[0]):
        ax.plot(
            X[i, :], Y[i, :], Z[i, :],
            linewidth=line_width,
            color=color
        )

    # Lines along grid size for selected time locations
    n_time_lines = min(21, Z.shape[1])
    time_indices = np.unique(
        np.linspace(0, Z.shape[1] - 1, n_time_lines).astype(int)
    )

    for j in time_indices:
        ax.plot(
            X[:, j], Y[:, j], Z[:, j],
            linewidth=line_width,
            color=color
        )

def style_3d_axes(ax, zlabel):
    ax.set_xlabel(r"Dimensionless time, $\tau=t/t_{\max}$",
                  labelpad=24, fontsize=24, fontweight="bold")
    ax.set_ylabel("Grid dimension",
                  labelpad=30, fontsize=24, fontweight="bold")
    ax.set_zlabel(zlabel,
                  labelpad=34, fontsize=24, fontweight="bold")

    ax.tick_params(axis="x", labelsize=18, width=1.5, pad=6)
    ax.tick_params(axis="y", labelsize=18, width=1.5, pad=6)
    ax.tick_params(axis="z", labelsize=18, width=1.5, pad=10)

    # Use grid-dimension labels on the 3D y-axis.
    try:
        ax.set_yticks(grid_index)
        ax.set_yticklabels(grid_labels_for_wire, fontsize=14, fontweight="bold")
    except Exception:
        pass

    # Give labels more room so vertical axis labels are not clipped.
    ax.xaxis.label.set_clip_on(False)
    ax.yaxis.label.set_clip_on(False)
    ax.zaxis.label.set_clip_on(False)

    ax.view_init(elev=28, azim=-135)

    # Slightly enlarge the visible box and improve proportions.
    try:
        ax.set_box_aspect((1.35, 1.0, 0.75))
    except Exception:
        pass



