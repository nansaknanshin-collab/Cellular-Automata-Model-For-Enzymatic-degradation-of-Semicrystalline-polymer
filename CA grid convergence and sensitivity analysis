def format_lattice_cell_axis(ax):
    """Format large lattice-cell counts so tick labels do not overlap."""
    ax.ticklabel_format(axis="x", style="sci", scilimits=(0, 0))
    ax.xaxis.get_offset_text().set_fontsize(18)
    ax.xaxis.get_offset_text().set_fontweight("bold")
    ax.xaxis.set_major_locator(MaxNLocator(nbins=5))
    ax.tick_params(axis="x", labelrotation=0, pad=8)

def format_grid_dimension_axis(ax, labels, rotation=25):
    """
    Use grid dimensions such as 10x333, 20x666, etc.
    This avoids crowded large-number total-cell labels.
    """
    x = np.arange(len(labels))
    ax.set_xticks(x)
    ax.set_xticklabels(
        labels,
        rotation=rotation,
        ha="right",
        fontsize=16,
        fontweight="bold"
    )
    ax.margins(x=0.04)
